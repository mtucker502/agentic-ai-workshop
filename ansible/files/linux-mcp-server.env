# Linux MCP Server Configuration

# Required: Remote host connection details
LINUX_HOST=localhost
LINUX_PORT=22
LINUX_USERNAME=claude

# Authentication: SSH key authentication (recommended)
LINUX_SSH_KEY_PATH=/home/claude/.ssh/id_rsa_claude

# Optional: Connection timeout in seconds
LINUX_TIMEOUT=30

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# MAXIMUM SAFETY CONFIGURATION
# Enable/disable warnings (default: true)
LINUX_ENABLE_WARNINGS=true

# Block critical commands entirely (default: false)
LINUX_BLOCK_CRITICAL=true

# Requires confirmation for high/critical commands (default: true)
LINUX_REQUIRE_CONFIRMATION=true
